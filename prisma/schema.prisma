// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "./generated"
  moduleFormat = "commonjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String     @id @default(uuid())
  name             String
  email            String     @unique
  password         String?
  avatarUrl        String?    @map("avatar_url")
  bio              String?
  role             Role       @default(ADMIN)
  provider         String? // 'local' | 'google'
  providerId       String?    @map("provider_id")
  resetToken       String?    @map("reset_token")
  resetTokenExpiry DateTime?  @map("reset_token_expiry")
  createdAt        DateTime   @default(now()) @map("created_at")
  blogPosts        BlogPost[]

  @@map("users")
}

model Project {
  id           String              @id @default(uuid())
  title        String
  slug         String              @unique
  description  String?
  objective    String?
  solution     String?
  thumbnailUrl String?             @map("thumbnail_url")
  images       String[]
  demoUrl      String?             @map("demo_url")
  repoUrl      String?             @map("repo_url")
  status       ProjectStatus       @default(DRAFT)
  statusTags   String[]            @map("status_tags")
  year         Int?
  features     String[]
  order        Int                 @default(0)
  createdAt    DateTime            @default(now()) @map("created_at")
  technologies ProjectTechnology[]

  @@map("projects")
}

model Technology {
  id       String              @id @default(uuid())
  name     String
  iconUrl  String?             @map("icon_url")
  category TechCategory
  order    Int                 @default(0)
  projects ProjectTechnology[]

  @@map("technologies")
}

model ProjectTechnology {
  projectId    String     @map("project_id")
  technologyId String     @map("technology_id")
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  technology   Technology @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@id([projectId, technologyId])
  @@map("project_technologies")
}

model BlogPost {
  id           String     @id @default(uuid())
  authorId     String     @map("author_id")
  title        String
  slug         String     @unique
  content      String
  thumbnailUrl String?    @map("thumbnail_url")
  status       PostStatus @default(DRAFT)
  publishedAt  DateTime?  @map("published_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  author       User       @relation(fields: [authorId], references: [id])
  tags         PostTag[]

  @@map("blog_posts")
}

model Tag {
  id    String    @id @default(uuid())
  name  String
  slug  String    @unique
  posts PostTag[]

  @@map("tags")
}

model PostTag {
  postId String   @map("post_id")
  tagId  String   @map("tag_id")
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

model ContactMessage {
  id        String        @id @default(uuid())
  name      String
  email     String
  message   String
  status    MessageStatus @default(UNREAD)
  createdAt DateTime      @default(now()) @map("created_at")

  @@map("contact_messages")
}

model Experience {
  id          String   @id @default(uuid())
  role        String
  companyName String   @map("company_name")
  date        String
  year        String
  description String
  techStack   String[] @map("tech_stack")
  order       Int      @default(0)

  @@map("experiences")
}

model Service {
  id    String @id @default(uuid())
  num   String
  name  String
  desc  String
  order Int    @default(0)

  @@map("services")
}

model Testimonial {
  id          String   @id @default(uuid())
  authorName  String   @map("author_name")
  authorRole  String?  @map("author_role")
  authorPhoto String?  @map("author_photo")
  content     String
  isVisible   Boolean  @default(false)       @map("is_visible")
  createdAt   DateTime @default(now())       @map("created_at")

  @@map("testimonials")
}

enum Role {
  ADMIN
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TechCategory {
  LANGUAGE
  FRAMEWORK
  TOOL
  DATABASE
  DESIGN
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum MessageStatus {
  UNREAD
  READ
  REPLIED
}
